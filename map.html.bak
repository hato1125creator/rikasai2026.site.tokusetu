<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>会場マップ — 梨花祭2026</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400&family=Noto+Serif+JP:wght@300;400;500&family=Cinzel:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{
  --gold:#d4a843;--gold-light:#f0d080;--teal-light:#48b0b8;
  --cream:#fdf8f0;--ink:#1a120a;--ink-soft:#3a2818;--parchment:#f5ead8;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--cream);color:var(--ink);font-family:'Noto Serif JP',serif;}

/* NAV */
.top-nav{background:var(--ink);border-bottom:1px solid rgba(212,168,67,.2);padding:0 24px;position:sticky;top:0;z-index:200;}
.top-nav-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;height:52px;}
.back-btn{font-family:'Cinzel',serif;font-size:9px;letter-spacing:.25em;color:rgba(240,208,128,.5);text-decoration:none;display:flex;align-items:center;gap:8px;text-transform:uppercase;transition:color .2s;}
.back-btn:hover{color:var(--gold-light);}
.back-btn::before{content:'←';font-family:sans-serif;font-size:13px;}
.nav-sep{width:1px;height:20px;background:rgba(212,168,67,.15);margin:0 20px;}
.nav-site{font-family:'Noto Serif JP',serif;font-size:15px;font-weight:300;color:rgba(240,208,128,.4);letter-spacing:.1em;}
.nav-links{margin-left:auto;display:flex;}
.nav-links a{font-family:'Cinzel',serif;font-size:9px;letter-spacing:.2em;color:rgba(240,208,128,.4);text-decoration:none;padding:0 14px;text-transform:uppercase;transition:color .2s;}
.nav-links a:hover{color:var(--gold);}

/* ===== NAV ===== */
nav{background:var(--ink);padding:0 24px;position:sticky;top:0;z-index:100;}
.nav-inner{max-width:960px;margin:0 auto;display:flex;align-items:center;height:52px;gap:24px;flex-wrap:wrap;}
.nav-inner a{font-family:'Cinzel',serif;font-size:9px;letter-spacing:.2em;color:rgba(240,208,128,.4);text-decoration:none;text-transform:uppercase;transition:color .2s;}
.nav-inner a:hover{color:var(--gold);}

/* HERO */
.hero{background:var(--ink);padding:40px 24px 36px;position:relative;overflow:hidden;border-bottom:1px solid rgba(212,168,67,.12);}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 15% 60%,rgba(212,168,67,.07) 0%,transparent 55%);}
.hero-inner{max-width:1100px;margin:0 auto;position:relative;}
.eyebrow{font-family:'Cinzel',serif;font-size:9px;letter-spacing:.4em;color:var(--gold);opacity:.6;text-transform:uppercase;display:block;margin-bottom:10px;}
.hero-title{font-family:'Noto Serif JP',serif;font-size:clamp(22px,3.5vw,34px);font-weight:300;color:var(--gold-light);letter-spacing:.15em;margin-bottom:6px;}
.hero-sub{font-family:'Cormorant Garamond',serif;font-size:14px;font-style:italic;color:rgba(240,208,128,.4);letter-spacing:.15em;}

/* HINT */
.hint{max-width:1100px;margin:28px auto 0;padding:0 24px;}
.hint-text{font-family:'Cinzel',serif;font-size:9px;letter-spacing:.25em;color:rgba(58,40,24,.4);text-transform:uppercase;display:flex;align-items:center;gap:8px;}
.hint-text::before{content:'';display:inline-block;width:6px;height:6px;background:var(--gold);border-radius:50%;opacity:.6;}

/* BUILDING GRID */
.grid-wrap{max-width:1100px;margin:20px auto 60px;padding:0 24px;}
.bldg-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  grid-template-rows:auto;
  gap:8px;
}
@media(max-width:640px){.bldg-grid{grid-template-columns:1fr 1fr;}}

/* Each block */
.bldg{
  position:relative;cursor:pointer;
  border:3px solid rgba(255,255,255,0);
  transition:filter .2s,transform .2s,border-color .2s,box-shadow .2s;
  min-height:140px;
}
.bldg:hover{filter:brightness(1.1);transform:scale(1.025);z-index:2;border-color:rgba(255,255,255,.6);}
.bldg.active{border-color:#fff;box-shadow:0 0 0 3px rgba(255,255,255,.25);filter:brightness(1.15);z-index:3;}
.bldg-inner{padding:20px 18px 16px;height:100%;display:flex;flex-direction:column;justify-content:flex-end;}
.bldg-floors{font-family:'Cinzel',serif;font-size:8px;letter-spacing:.2em;opacity:.65;text-transform:uppercase;margin-bottom:8px;}
.bldg-en{font-family:'Cinzel',serif;font-size:clamp(13px,1.8vw,18px);font-weight:600;letter-spacing:.04em;line-height:1.2;margin-bottom:5px;}
.bldg-jp{font-size:12px;font-weight:300;opacity:.8;letter-spacing:.08em;}
.bldg-count{
  position:absolute;top:12px;right:14px;
  font-family:'Cinzel',serif;font-size:11px;font-weight:600;
  background:rgba(0,0,0,.22);border-radius:50%;
  width:26px;height:26px;display:flex;align-items:center;justify-content:center;
  color:#fff;
}
/* grid placement & colors */
.b-tamokuteki{background:#f4a22d;color:#fff; grid-column:1;grid-row:1/3;min-height:290px;}
.b-taiiku    {background:#e85d44;color:#fff; grid-column:2;grid-row:1;}
.b-shinkosha {background:#e2c840;color:#1a120a;grid-column:3;grid-row:1;}
.b-kyukosha  {background:#6ec46e;color:#1a120a;grid-column:2;grid-row:2;}
.b-groupwork {background:#e87db0;color:#fff; grid-column:3;grid-row:2;}
.b-chapel    {background:#7eb8e0;color:#fff; grid-column:1;grid-row:3;}
.b-outdoor   {background:#b09060;color:#fff; grid-column:2/4;grid-row:3;}

/* LEGEND */
.legend{display:flex;flex-wrap:wrap;gap:10px;margin-top:16px;}
.lg-item{display:flex;align-items:center;gap:6px;font-family:'Cinzel',serif;font-size:8px;letter-spacing:.1em;color:rgba(58,40,24,.5);text-transform:uppercase;}
.lg-dot{width:10px;height:10px;border-radius:2px;flex-shrink:0;}

/* ── MODAL（棟一覧）── */
.overlay{position:fixed;inset:0;background:rgba(10,8,4,.6);backdrop-filter:blur(4px);z-index:500;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .3s;}
.overlay.open{opacity:1;pointer-events:all;}
.modal{
  background:#fff;
  border-top:5px solid var(--gold);
  border-radius:2px;
  box-shadow:0 24px 64px rgba(0,0,0,.25);
  max-width:600px;width:100%;max-height:90vh;
  overflow-y:auto;position:relative;
  transform:translateY(18px) scale(.98);
  transition:transform .35s cubic-bezier(.34,1.2,.64,1);
}
.overlay.open .modal{transform:translateY(0) scale(1);}
.modal-close{
  position:sticky;top:0;float:right;
  margin:12px 12px 0 0;
  width:36px;height:36px;
  background:#f0ede8;border:1px solid #d0c8b8;
  color:#3a2818;font-size:16px;font-weight:700;
  cursor:pointer;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  transition:background .2s;z-index:10;
}
.modal-close:hover{background:#e0d8c8;}

/* Modal: building header */
.modal-bldg-header{padding:20px 24px 16px;border-bottom:2px solid #f0ede8;clear:both;}
.modal-bldg-color{width:100%;height:8px;margin-bottom:16px;border-radius:2px;}
.modal-bldg-floors{font-family:'Cinzel',serif;font-size:8px;letter-spacing:.3em;color:var(--gold);text-transform:uppercase;margin-bottom:6px;display:block;}
.modal-bldg-title{font-family:'Noto Serif JP',serif;font-size:20px;font-weight:500;color:var(--ink);margin-bottom:4px;}
.modal-bldg-desc{font-size:12px;color:#6a5a48;font-weight:300;}

/* Modal: floor sections */
.modal-body{padding:16px 24px 28px;}
.modal-floor-section{margin-bottom:16px;}
.modal-floor-label{
  font-family:'Cinzel',serif;font-size:9px;letter-spacing:.25em;
  color:var(--gold);text-transform:uppercase;
  padding:6px 0 8px;border-bottom:2px solid #f0ede8;
  margin-bottom:10px;display:flex;align-items:center;gap:8px;
}
.modal-floor-label::before{content:'';display:inline-block;width:4px;height:4px;background:var(--gold);border-radius:50%;}

/* Event row */
.ev-row{
  display:flex;gap:12px;align-items:flex-start;
  padding:11px 12px;border:1px solid #e8e0d0;
  background:#fdf9f4;margin-bottom:7px;
  cursor:pointer;transition:all .2s;border-radius:2px;
}
.ev-row:hover{border-color:var(--gold);background:#faf3e6;box-shadow:0 2px 8px rgba(212,168,67,.15);}
.ev-emoji{font-size:22px;line-height:1;flex-shrink:0;margin-top:2px;}
.ev-body{flex:1;min-width:0;}
.ev-meta{font-family:'Cinzel',serif;font-size:7px;letter-spacing:.18em;color:var(--gold);text-transform:uppercase;margin-bottom:3px;}
.ev-name{font-size:14px;font-weight:500;color:var(--ink);line-height:1.35;margin-bottom:4px;}
.ev-badge{display:inline-block;font-size:9px;padding:1px 9px;border:1px solid;margin-bottom:4px;}
.ev-room{font-size:11px;color:#8a7a68;font-weight:300;}
.ev-arrow{font-size:16px;color:#c8b898;flex-shrink:0;margin-top:4px;transition:color .2s;}
.ev-row:hover .ev-arrow{color:var(--gold);}

/* ── DETAIL MODAL（企画詳細）── */
.detail-overlay{position:fixed;inset:0;background:rgba(10,8,4,.65);backdrop-filter:blur(5px);z-index:600;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .3s;}
.detail-overlay.open{opacity:1;pointer-events:all;}
.detail-modal{
  background:#fff;
  border-top:5px solid var(--teal-light);
  border-radius:2px;
  box-shadow:0 24px 64px rgba(0,0,0,.3);
  max-width:520px;width:100%;max-height:88vh;
  overflow-y:auto;position:relative;
  transform:translateY(14px) scale(.98);
  transition:transform .3s cubic-bezier(.34,1.2,.64,1);
}
.detail-overlay.open .detail-modal{transform:translateY(0) scale(1);}
.detail-close{
  position:sticky;top:0;float:right;
  margin:12px 12px 0 0;
  width:36px;height:36px;
  background:#f0ede8;border:1px solid #d0c8b8;
  color:#3a2818;font-size:16px;font-weight:700;
  cursor:pointer;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  transition:background .2s;z-index:10;
}
.detail-close:hover{background:#e0d8c8;}
.detail-header{padding:20px 24px 16px;border-bottom:2px solid #f0ede8;clear:both;}
.detail-emoji{font-size:40px;margin-bottom:10px;display:block;}
.detail-grade{font-family:'Cinzel',serif;font-size:8px;letter-spacing:.3em;color:var(--gold);text-transform:uppercase;margin-bottom:6px;}
.detail-title{font-family:'Noto Serif JP',serif;font-size:18px;font-weight:500;color:var(--ink);margin-bottom:8px;line-height:1.4;}
.detail-type{display:inline-block;font-size:9px;padding:2px 10px;border:1px solid;border-radius:2px;}
.detail-body{padding:16px 24px 28px;}
.d-label{font-family:'Cinzel',serif;font-size:8px;letter-spacing:.3em;color:var(--gold);text-transform:uppercase;margin:16px 0 8px;display:block;}
.d-label:first-child{margin-top:0;}
.d-desc{font-size:13px;color:#4a3a28;line-height:2;font-weight:300;}
.d-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
@media(max-width:480px){.d-info-grid{grid-template-columns:1fr;}}
.d-info-item{background:#fdf9f4;border:1px solid #e8e0d0;padding:10px 12px;border-radius:2px;}
.d-info-key{font-family:'Cinzel',serif;font-size:8px;letter-spacing:.2em;color:var(--gold);display:block;margin-bottom:4px;}
.d-info-val{font-size:13px;color:var(--ink-soft);font-weight:400;}
.d-tags{display:flex;flex-wrap:wrap;gap:6px;}
.d-tag{font-family:'Cinzel',serif;font-size:8px;letter-spacing:.1em;padding:4px 10px;border:1px solid rgba(72,176,184,.5);color:var(--teal-light);border-radius:2px;}

footer{background:var(--ink);padding:36px 24px;text-align:center;border-top:1px solid rgba(212,168,67,.1);margin-top:0;}
.footer-logo{font-family:'Noto Serif JP',serif;font-size:18px;font-weight:300;color:var(--gold-light);letter-spacing:.2em;margin-bottom:6px;}
.footer-copy{font-size:11px;color:rgba(240,208,128,.2);font-weight:300;}
</style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="about.html">梨花祭とは</a>
    <a href="attractions.html">企画一覧</a>
    <a href="map.html">マップ</a>
    <a href="schedule.html">プログラム</a>
    <a onclick="scrollToSection('notice')">お知らせ</a>
    <a onclick="scrollToSection('award')">梨花祭賞</a>
    <a href="gallery.html">ギャラリー</a>
    <a href="rules.html">ご注意</a>
    <a href="ticket.html">料金</a>
    <a href="sns.html">SNS</a>
    <a onclick="scrollToSection('access')">アクセス</a>
  </div>
</nav>

<section class="hero">
  <div class="hero-inner">
    <span class="eyebrow">Venue Guide — 梨花祭2026</span>
    <h1 class="hero-title">会場マップ</h1>
    <p class="hero-sub">Venue Map &amp; Exhibition Guide</p>
  </div>
</section>


<div class="hint"><p class="hint-text">棟をクリックすると企画一覧が表示されます</p></div>

<!-- OVERVIEW MAP -->
<div style="max-width:1100px;margin:24px auto 0;padding:0 24px;">
  <div style="position:relative;background:#d4c9b0;border:1px solid rgba(212,168,67,.25);overflow:hidden;">
    <div style="padding:10px 16px 6px;border-bottom:1px solid rgba(212,168,67,.15);display:flex;align-items:center;justify-content:space-between;">
      <span style="font-family:'Cinzel',serif;font-size:9px;letter-spacing:.3em;color:#d4a843;text-transform:uppercase;opacity:.8;">Campus Overview Map</span>
      <span style="font-family:'Noto Serif JP',serif;font-size:11px;color:#8a7a68;font-weight:300;">全体図 — 棟をクリックで企画一覧へ</span>
    </div>
    <img src="data:image/png;base64," alt="会場全体マップ" style="width:100%;display:block;">
  </div>
</div>

<div class="grid-wrap">
  <div class="bldg-grid">

    <div class="bldg b-tamokuteki" onclick="openBldg('tamokuteki')">
      <div class="bldg-inner">
        <div class="bldg-floors">3F</div>
        <div class="bldg-en">MULTIPURPOSE<br>BLDG</div>
        <div class="bldg-jp">多目的教室棟</div>
      </div>
      <div class="bldg-count">6</div>
    </div>

    <div class="bldg b-taiiku" onclick="openBldg('taiiku')">
      <div class="bldg-inner">
        <div class="bldg-floors">2F</div>
        <div class="bldg-en">GYM</div>
        <div class="bldg-jp">体育館</div>
      </div>
      <div class="bldg-count">4</div>
    </div>

    <div class="bldg b-shinkosha" onclick="openBldg('shinkosha')">
      <div class="bldg-inner">
        <div class="bldg-floors">3F</div>
        <div class="bldg-en">NEW BUILDING</div>
        <div class="bldg-jp">新校舎棟</div>
      </div>
      <div class="bldg-count">6</div>
    </div>

    <div class="bldg b-kyukosha" onclick="openBldg('kyukosha')">
      <div class="bldg-inner">
        <div class="bldg-floors">3F</div>
        <div class="bldg-en">OLD BUILDING</div>
        <div class="bldg-jp">旧校舎棟</div>
      </div>
      <div class="bldg-count">6</div>
    </div>

    <div class="bldg b-groupwork" onclick="openBldg('groupwork')">
      <div class="bldg-inner">
        <div class="bldg-floors">3F</div>
        <div class="bldg-en">GROUP WORK<br>BLDG</div>
        <div class="bldg-jp">グループワーク棟</div>
      </div>
      <div class="bldg-count">6</div>
    </div>

    <div class="bldg b-chapel" onclick="openBldg('chapel')">
      <div class="bldg-inner">
        <div class="bldg-floors">CHAPEL</div>
        <div class="bldg-en">CHAPEL</div>
        <div class="bldg-jp">チャペル（講堂）</div>
      </div>
      <div class="bldg-count">3</div>
    </div>

    <div class="bldg b-outdoor" onclick="openBldg('outdoor')">
      <div class="bldg-inner">
        <div class="bldg-floors">OUTDOOR</div>
        <div class="bldg-en">OUTDOOR AREA</div>
        <div class="bldg-jp">屋外・中庭エリア</div>
      </div>
      <div class="bldg-count">4</div>
    </div>

  </div>

  <div class="legend">
    <div class="lg-item"><div class="lg-dot" style="background:#f4a22d"></div>多目的教室棟</div>
    <div class="lg-item"><div class="lg-dot" style="background:#e85d44"></div>体育館</div>
    <div class="lg-item"><div class="lg-dot" style="background:#e2c840"></div>新校舎棟</div>
    <div class="lg-item"><div class="lg-dot" style="background:#6ec46e"></div>旧校舎棟</div>
    <div class="lg-item"><div class="lg-dot" style="background:#e87db0"></div>グループワーク棟</div>
    <div class="lg-item"><div class="lg-dot" style="background:#7eb8e0"></div>チャペル</div>
    <div class="lg-item"><div class="lg-dot" style="background:#b09060"></div>屋外</div>
  </div>
</div>

<!-- BUILDING MODAL -->
<div class="overlay" id="bldgOverlay" onclick="handleBldgOverlay(event)">
  <div class="modal" id="bldgModal">
    <button class="modal-close" onclick="closeBldg()">✕</button>
    <div class="modal-bldg-header">
      <div class="modal-bldg-color" id="mb-color"></div>
      <span class="modal-bldg-floors" id="mb-floors"></span>
      <div class="modal-bldg-title"  id="mb-title"></div>
      <div class="modal-bldg-desc"   id="mb-desc"></div>
    </div>
    <div class="modal-body" id="mb-body"></div>
  </div>
</div>

<!-- DETAIL MODAL -->
<div class="detail-overlay" id="detailOverlay" onclick="handleDetailOverlay(event)">
  <div class="detail-modal">
    <button class="detail-close" onclick="closeDetail()">✕</button>
    <div class="detail-header">
      <span class="detail-emoji" id="d-emoji"></span>
      <p class="detail-grade"    id="d-grade"></p>
      <h2 class="detail-title"   id="d-title"></h2>
      <span class="detail-type"  id="d-type"></span>
    </div>
    <div class="detail-body">
      <span class="d-label">About</span>
      <p class="d-desc" id="d-desc"></p>
      <span class="d-label">Info</span>
      <div class="d-info-grid" id="d-info"></div>
      <span class="d-label">Keywords</span>
      <div class="d-tags" id="d-tags"></div>
    </div>
  </div>
</div>

<footer>
  <p class="footer-logo">梨花祭 2026</p>
  <p class="footer-copy">© 2026 梨花祭実行委員会 · 千葉英和高等学校生徒会</p>
</footer>

<script>
const BUILDINGS = {
  tamokuteki:{
    label:'多目的教室棟', floors:'3階建て', color:'#f4a22d',
    desc:'飲食・体験・展示の中心エリア',
    events:[
      {floor:'1F',id:'t01',emoji:'☕',grade:'1年A組',name:'おとぎ話カフェ',type:'飲食',tc:'#f08898',room:'1F 教室A',
       desc:'童話をモチーフにしたドリンク・フードが揃う特別カフェ。シンデレラのパンプキンラテ、白雪姫のリンゴジュースなど物語にちなんだメニューが並びます。',
       info:[{k:'場所',v:'1F 教室A'},{k:'営業',v:'10:00–15:30'},{k:'定員',v:'20名（入替制）'},{k:'料金',v:'300円〜'}],tags:['カフェ','ドリンク','フォトスポット']},
      {floor:'1F',id:'t02',emoji:'🍖',grade:'1年E組',name:'王様の宴 屋台',type:'飲食',tc:'#f08898',room:'1F 廊下',
       desc:'中世ヨーロッパ風宴会コンセプトの屋台。から揚げ・チーズドッグ・クレープなどボリューム満点のメニューを提供します。',
       info:[{k:'場所',v:'1F 廊下'},{k:'営業',v:'10:30–14:30'},{k:'支払い',v:'現金のみ'},{k:'料金',v:'200円〜'}],tags:['屋台','フード','テイクアウト']},
      {floor:'2F',id:'t03',emoji:'🔮',grade:'1年B組',name:'魔法使いの謎解き迷宮',type:'体験',tc:'#48b0b8',room:'2F 教室B',
